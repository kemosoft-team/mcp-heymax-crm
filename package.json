{
  "name": "mcp-heymax-crm",
  "version": "0.1.0",
  "description": "MCP server for the HeyMax CRM customer service API",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-heymax-crm": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "node scripts/smoke-test.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "node -e \"import('node:fs/promises').then(fs => fs.rm('dist', { recursive: true, force: true }))\"",
    "prepack": "npm run clean && npm run build && npm run smoke"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kemosoft-team/mcp-heymax-crm.git"
  },
  "bugs": {
    "url": "https://github.com/kemosoft-team/mcp-heymax-crm/issues"
  },
  "homepage": "https://github.com/kemosoft-team/mcp-heymax-crm#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "crm",
    "typescript",
    "model-context-protocol",
    "heymax",
    "kemosoft"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
